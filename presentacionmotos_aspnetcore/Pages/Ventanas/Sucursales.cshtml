        @if (Model.ListaSucursales != null && Model.ListaSucursales.Any())
        {
            <div class="mt-5">
                <h2 class="mb-4">Motos disponibles en @Model.Departamento</h2>
        
                @foreach (var sucursal in Model.ListaSucursales)
                {
                    <div class="card mb-3 shadow">
                        <div class="card-header bg-primary text-white">
                            <h5>@sucursal.Ciudad - @sucursal.Direccion</h5>
                        </div>
                        <div class="card-body">
                            @if (sucursal.InventarioMotos != null && sucursal.InventarioMotos.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead class="table-dark">
                                            <tr>
                                                <th>Id</th>
                                                <th>Cantidad</th>
                                                <th>Estado</th>
                                                <th>Moto Id</th>
                                                <th>Último Conteo</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in sucursal.InventarioMotos)
                                            {
                                                <tr>
                                                    <td>@item.Id</td>
                                                    <td>
                                                        <span class="badge @(item.Cantidad > 5 ? "bg-success" :
                                                                                                                                                                      item.Cantidad > 0 ? "bg-warning" : "bg-danger")">
                                                            @item.Cantidad
                                                        </span>
                                                    </td>
                                                    <td>@item.Estado</td>
                                                    <td>@item.MotosId</td>
                                                    <td>@item.UltimoConteo.ToString("dd/MM/yyyy")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info">
                                    No hay motos registradas en esta sucursal
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else if (!string.IsNullOrEmpty(Model.Departamento))
        {
            <div class="alert alert-warning mt-5">
                No se encontraron motos en @Model.Departamento
            </div>
        }
                <script>
                                    document.addEventListener('DOMContentLoaded', function () {
                                        var tooltip = document.createElement('div');
                                        tooltip.id = 'mapa-tooltip';
                                        tooltip.style.cssText = `
                                            position: absolute;
                                            background: rgba(0, 0, 0, 0.85);
                                            color: white;
                                            padding: 8px 15px;
                                            border-radius: 8px;
                                            font-size: 14px;
                                            font-weight: bold;
                                            pointer-events: none;
                                            z-index: 10000;
                                            display: none;
                                            white-space: nowrap;
                                            box-shadow: 0 4px 8px rgba(0,0,0,0.3);
                                        `;
                                        document.body.appendChild(tooltip);
        
                                        var paths = document.querySelectorAll('svg path[id]');
                                        console.log('Paths encontrados:', paths.length);
        
                                        paths.forEach(function(path) {
                                            path.style.cursor = 'pointer';
            
                                            // Mostrar tooltip al entrar
                                            path.addEventListener('mouseenter', function(e) {
                                                var nombre = this.getAttribute('name') || this.getAttribute('title');
                                                if (nombre) {
                                                    tooltip.textContent = nombre;
                                                    tooltip.style.display = 'block';
                                                    // Efecto hover
                                                    this.style.opacity = '0.7';
                                                    this.style.fill = '#4CAF50';
                                                }
                                            });
            
                                            // Mover tooltip con el mouse
                                            path.addEventListener('mousemove', function(e) {
                                                tooltip.style.left = (e.pageX + 15) + 'px';
                                                tooltip.style.top = (e.pageY - 35) + 'px';
                                            });
            
                                            // Ocultar tooltip al salir
                                            path.addEventListener('mouseleave', function() {
                                                tooltip.style.display = 'none';
                                                this.style.opacity = '1';
                                                this.style.fill = '';
                                            });
            
                                            // Click
                                            path.addEventListener('click', function () {
                                                var nombre = this.getAttribute('name');
                                                console.log('Click detectado:', nombre);
                                                if (nombre) {
                                                    document.getElementById('departamentoSeleccionado').value = nombre;
                                                    document.getElementById('formDepartamento').submit();
                                                }
                                            });
                                        });
                                    });
                </script>
    </div>
</div>
