@page
@model MotosModel
@{
    ViewData["Title"] = "Motos";
}

<center>
    <div>
        <form method="POST"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Motos</h3>
            </div>

            <div>
                <input type="submit"
                       value="Refrescar"
                       class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                <input type="submit"
                       value="Nuevo"
                       class="btn btn-secondary"
                       asp-page-handler="BtNuevo"
                       disabled="@(Model.Moto != null)" />
                <input type="submit"
                       value="Guardar"
                       class="btn btn-secondary"
                       asp-page-handler="BtGuardar"
                       disabled="@(Model.Moto == null)" />
            </div>

            @if (Model.Moto != null)
            {
                <input type="hidden"
                       asp-for="@Model.Moto!.Id" />

                <div>
                    <div class="form-group">
                        <label>
                            Id
                        </label>
                        <div class="col-6">
                            <input id="inId"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Moto!.Id" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>
                            Placa
                        </label>
                        <div class="col-6">
                            <input id="inPlaca"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Moto!.Placa" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>
                            ModelosId
                        </label>
                        <div class="col-6">
                            <input id="inModelosId"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Moto!.ModelosId" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>
                            MarcasId
                        </label>
                        <div class="col-6">
                            <input id="inMarcasId"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Moto!.MarcasId" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>
                            Valor
                        </label>
                        <div class="col-6">
                            <input id="inValor"
                                   asp-for="@Model.Moto!.Valor" />
                        </div>
                    </div>
                </div>
            }
            
            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
                ;
            }

            @if (Model.Moto != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left">
                                Mensaje
                            </h2>

                            <h6 align="left">
                                Desea borrar la Moto?
                            </h6>
                            <h6 align="left">
                                @Model.Moto!.Id
                            </h6>
                            
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null &&
                 Model.Lista != null &&
                 Model.Lista.Count > 0)
            {
                <table class="tb_data table table-striped table-bordered table-hover">
                    <tr>
                        <th>
                            Id
                        </th>
                        <th>
                            Placa
                        </th>
                        <th>
                            ModelosId
                        </th>
                        <th class="cl_hidden">
                            MarcasId
                        </th>
                        <th class="cl_hidden">
                            Valor
                        </th>
                    </tr>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>
                                @elemento.Id
                            </td>
                            <td>
                                @elemento.Placa
                            </td>
                            <td>
                                @elemento.ModelosId
                            </td>
                            <td class="cl_hidden">
                                @elemento.MarcasId
                            </td>
                            <td class="cl_hidden">
                                @elemento.Valor
                            </td>
                            <td>
                                <input type="submit"
                                       value="Modicar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                                <input type="submit"
                                       value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>
